    "df = pd.read_csv('bank.csv')\n",
    "corr = df.corr(numeric_only=True)\n",
    "print(corr)\n",
    "plt.figure(figsize=(10,6))\n",
    "sns.heatmap(corr, annot=True, cmap='coolwarm')\n",
    "plt.title(\"Correlation Heatmap\")\n",
    "plt.show()"
   ]
